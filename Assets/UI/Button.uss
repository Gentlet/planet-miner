.root {
    width: 100%;
    height: 100%;
}

.bottom-button-container {
    position: absolute;
    bottom: 30px;
    left: 0;
    right: 0;

    flex-direction: row;
    justify-content: center;
    align-items: center;

    gap: 20px;
}

.bottom-button {
    width: 160px;
    height: 60px;

    font-size: 22px;
}